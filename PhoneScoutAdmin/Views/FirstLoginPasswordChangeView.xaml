<UserControl x:Class="PhoneScoutAdmin.Views.FirstLoginPasswordChangeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="LightGray">
    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">

            <TextBlock Text="Jelszó beállítása" FontSize="20" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <PasswordBox x:Name="CurrentPasswordBox" Margin="0,5" Height="30" 
                         PasswordChanged="CurrentPasswordBox_PasswordChanged" 
                         />

            <PasswordBox x:Name="NewPasswordBox" Margin="0,5" Height="30" 
                         PasswordChanged="NewPasswordBox_PasswordChanged" 
                         />

            <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,5" Height="30" 
                         PasswordChanged="ConfirmPasswordBox_PasswordChanged" 
                         />

            <Button Content="Mentés" Margin="0,10" Height="35" Command="{Binding ChangePasswordCommand}"/>

            <!-- Fixed binding to match ViewModel -->
            <TextBlock Text="{Binding StatusMessage}" Foreground="Red" Margin="0,10" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>