<UserControl x:Class="PhoneScoutAdmin.Views.FirstLoginPasswordChangeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="580" Width="270">

    <Grid Background="#F5F5F5">
        <!-- Centered fixed container -->
        <Border Width="270"
                Height="580"
                Background="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20"
                CornerRadius="6">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="200"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Image Source="/Images/PhoneScoutLogo.png"
                       HorizontalAlignment="Center"
                       Margin="10"/>

                <!-- Title -->
                <TextBlock Grid.Row="1"
                           Text="Set password"
                           Margin="0,10"
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           FontSize="24"/>

                <!-- Password Fields -->
                <StackPanel Grid.Row="2"
                            HorizontalAlignment="Center">

                    <Label Content="Old password:"
                           FontSize="15"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"/>
                    <PasswordBox x:Name="CurrentPasswordBox"
                                 Width="200"
                                 Margin="0,5"
                                 PasswordChanged="CurrentPasswordBox_PasswordChanged" BorderBrush="#2300B3"/>

                    <Label Content="New password:"
                           Margin="0,10,0,0"
                           FontSize="15"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"/>
                    <PasswordBox x:Name="NewPasswordBox"
                                 Width="200"
                                 Margin="0,5"
                                 PasswordChanged="NewPasswordBox_PasswordChanged" BorderBrush="#80A4CB"/>

                    <Label Content="Confirm new password:"
                           Margin="0,10,0,0"
                           FontSize="15"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Width="200"
                                 Margin="0,5"
                                 PasswordChanged="ConfirmPasswordBox_PasswordChanged" BorderBrush="#68F145"/>
                </StackPanel>

                <!-- Button -->
                <Button Grid.Row="3"
                        Content="Set password"
                        Width="180"
                        Margin="0,20,0,10"
                        Padding="5"
                        Background="White"
                        Foreground="#80A4CB"
                        BorderBrush="#80A4CB"
                        BorderThickness="3"
                        HorizontalAlignment="Center"
                        Command="{Binding ChangePasswordCommand}"/>

            </Grid>

        </Border>
    </Grid>
</UserControl>