<UserControl x:Class="PhoneScoutAdmin.Views.ImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="LightGray">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Images"
                  Grid.Row="0"
                  Margin="5"
                  Padding="15"
                  BorderBrush="#2300B3"
                  BorderThickness="2">

            <StackPanel>
                <Button Content="Add Images"
                        Height="35"
                        Margin="5"
                        Command="{Binding AddImageCommand}"/>

                <TextBlock Text="Upload images. You can mark one as index."
                           Margin="5"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Images Preview"
                  Grid.Row="1"
                  Margin="5"
                  Padding="10"
                  BorderBrush="#68F145"
                  BorderThickness="2">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Images}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="160"
                                  Height="200"
                                  Margin="8">

                                <Border BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Background="White">
                                    <Image Source="{Binding Preview}"
                                           Width="150"
                                           Height="150"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>

                                <!-- INDEX CHECKBOX -->
                                <CheckBox Content="Index"
                                          IsChecked="{Binding IsIndex, Mode=TwoWay}"
                                          Command="{Binding DataContext.SetIndexCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          CommandParameter="{Binding}"
                                          Margin="0,155,0,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                          Padding="4"/>

                                <!-- REMOVE BUTTON -->
                                <Button Content="X"
                                        Width="25"
                                        Height="25"
                                        FontWeight="Bold"
                                        Background="Red"
                                        Foreground="White"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="5"
                                        Command="{Binding DataContext.RemoveImageCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>

                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>

        </GroupBox>

    </Grid>
</UserControl>