<UserControl x:Class="PhoneScoutAdmin.Views.ImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="LightGray">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Images"
                  Grid.Row="0"
                  Margin="5"
                  Padding="15"
                  BorderBrush="#2300B3"
                  BorderThickness="2">

            <StackPanel>

                <Button Grid.Row="3"
        Grid.ColumnSpan="2"
        Margin="10,15,10,0"
        Padding="5"
        FontSize="18"
        Background="WhiteSmoke"
        BorderBrush="#68F145"
        BorderThickness="3"
        Content="Add Images"
        Command="{Binding AddImageCommand}" />
               
                <TextBlock Text="Upload images. You can mark one as index."
                           Margin="5"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Images Preview"
                  Grid.Row="1"
                  Margin="5"
                  Padding="10"
                  BorderBrush="#68F145"
                  BorderThickness="2">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Images}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="160"
                                  Height="200"
                                  Margin="8">

                                <Border BorderBrush="Gray"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Background="White">
                                    <Image Source="{Binding Preview}"
                                           Width="150"
                                           Height="150"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Border>

                                <!-- INDEX CHECKBOX -->
                                <CheckBox
    IsChecked="{Binding IsIndex, Mode=TwoWay}"
    Command="{Binding DataContext.SetIndexCommand,
              RelativeSource={RelativeSource AncestorType=UserControl}}"
    CommandParameter="{Binding}"
    Margin="0,150,0,0"
    HorizontalAlignment="Left"
    VerticalAlignment="Top" >

                                <TextBlock Text="Index"
               FontSize="20"
               FontWeight="Bold"
               Foreground="White"
               Background="Black"
                                               VerticalAlignment="Center" Padding="3"
               />
                                </CheckBox>

                                <!-- REMOVE BUTTON -->
                                <Button Content="X"
                                        Width="25"
                                        Height="25"
                                        FontWeight="Bold"
                                        Background="Red"
                                        Foreground="White"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="5"
                                        Command="{Binding DataContext.RemoveImageCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>

                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>

                </ItemsControl>
            </ScrollViewer>

        </GroupBox>

    </Grid>
</UserControl>