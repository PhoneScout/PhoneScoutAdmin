<UserControl x:Class="PhoneScoutAdmin.Views.EventView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="LightGray">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>


        <WrapPanel Grid.Row="0" Orientation="Horizontal" 
Grid.ColumnSpan="2">

            <TextBlock Text="Event host name:" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0,10,0" FontWeight="Bold"/>

            <TextBox Width="150"
 Height="20"
 Margin="5"
 Background="White"
 Text="{Binding EventHostNameFilter, UpdateSourceTrigger=PropertyChanged}" />


            


        </WrapPanel>
        <Button Grid.Row="0"
            Grid.Column="1"
            
            FontSize="14"
            Content="Create an event"
            BorderBrush="#2300B3"
        FontStyle="Italic"
        Padding="5,0,5,0"
            BorderThickness="3"
            Background="WhiteSmoke"
        HorizontalAlignment="Center"
            Command="{Binding CreateEventCommand}" />

        <!-- ===================== -->
        <!-- PHONE LIST -->
        <!-- ===================== -->

        <DataGrid Grid.Row="1"
                  Grid.Column="0"
                  ItemsSource="{Binding EventsView}"
                  SelectedItem="{Binding SelectedEvent}"
                  AutoGenerateColumns="False"
                  ColumnWidth="*"
                  Margin="5"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Event name" Binding="{Binding eventName}" />
                <DataGridTextColumn Header="Event host" Binding="{Binding eventHostName}" />
                <DataGridTextColumn Header="Event date" Binding="{Binding eventDate}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- ===================== -->
        <!-- EDIT PANEL -->
        <!-- ===================== -->

        <GroupBox Grid.Row="1"
                  Grid.Column="1"
                  Margin="5"
                  Padding="20"
                  Header="Modify the event details"
                  BorderBrush="#2300B3"
                  BorderThickness="2">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Phone Name -->
                <StackPanel Grid.Row="0"
       Grid.Column="0"
       Orientation="Horizontal"
       VerticalAlignment="Center">



                    <TextBlock Text="ℹ"
          FontSize="16"
Foreground="#2300B3"
          Cursor="Hand"
          VerticalAlignment="Center" ToolTipService.InitialShowDelay="500">

                        <TextBlock.ToolTip>
                            <ToolTip>
                                Displays the name of the event.
                            </ToolTip>
                        </TextBlock.ToolTip>

                    </TextBlock>
                    <TextBlock Text="Event name:"
          Margin="5,5,2,5"
          FontSize="16"
          VerticalAlignment="Center"/>
                </StackPanel>

                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="5"
                         Width="180"
                         Text="{Binding EventName, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Phone Price -->
                <StackPanel Grid.Row="1"
       Grid.Column="0"
       Orientation="Horizontal"
       VerticalAlignment="Center">



                    <TextBlock Text="ℹ"
          FontSize="16"
Foreground="#2300B3"
          Cursor="Hand"
          VerticalAlignment="Center" ToolTipService.InitialShowDelay="500">

                        <TextBlock.ToolTip>
                            <ToolTip>
                                Displays the name of the manufacturer, who will host the event.
                            </ToolTip>
                        </TextBlock.ToolTip>

                    </TextBlock>
                    <TextBlock Text="Host name:"
          Margin="5,5,2,5"
          FontSize="16"
          VerticalAlignment="Center"/>
                </StackPanel>

                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="5"
                         Width="180"
                         Text="{Binding EventHostName}" />

                <!-- In Store -->
                <StackPanel Grid.Row="2"
       Grid.Column="0"
       Orientation="Horizontal"
       VerticalAlignment="Center">



                    <TextBlock Text="ℹ"
          FontSize="16"
Foreground="#2300B3"
          Cursor="Hand"
          VerticalAlignment="Center" ToolTipService.InitialShowDelay="500">

                        <TextBlock.ToolTip>
                            <ToolTip>
                                Displays the start time of the event. Please select a date, then write a time in the format: HH:MM:SS. The time will be stored in UTC format.
                            </ToolTip>
                        </TextBlock.ToolTip>

                    </TextBlock>
                    <TextBlock Text="Event date:"
          Margin="5,5,2,5"
          FontSize="16"
          VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <DatePicker
          Grid.Column="1"
          Margin="5" Width="85"
          HorizontalAlignment="Center" VerticalAlignment="Center"
                        SelectedDate="{Binding EventDate, UpdateSourceTrigger=PropertyChanged}"
           />

                    <TextBox Grid.Row="1"
         Grid.Column="1"
         Margin="5"
         Width="85"
         Text="{Binding EventTime}" />


                </StackPanel>

                

                <!-- Available -->
                <StackPanel Grid.Row="3"
       Grid.Column="0"
       Orientation="Horizontal"
       VerticalAlignment="Center">



                    <TextBlock Text="ℹ"
          FontSize="16"
Foreground="#2300B3"
          Cursor="Hand"
          VerticalAlignment="Center" ToolTipService.InitialShowDelay="500">

                        <TextBlock.ToolTip>
                            <ToolTip>
                                Displays the URL of the event.
                            </ToolTip>
                        </TextBlock.ToolTip>

                    </TextBlock>
                    <TextBlock Text="Event URL:"
          Margin="5,5,2,5"
          FontSize="16"
          VerticalAlignment="Center"/>
                </StackPanel>

                <TextBox Grid.Row="3"
         Grid.Column="1"
         Margin="5"
         Width="180"
         Text="{Binding EventURL}" />
                
                <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="5">
                    <Image Width="150" Height="150"
           Margin="5"
           Source="{Binding EventImage}" />
                    <Button Grid.Row="5"
        Grid.ColumnSpan="2"
        Margin="10"
        Padding="5,0,5,0"
        FontSize="16"
        Content="Select image"
                            Height="50"  
        BorderBrush="#80A4CB"
        BorderThickness="3"
        Background="WhiteSmoke"
        Command="{Binding SelectFileCommand}" />
                    
                </StackPanel>


                <!-- Save -->
                <Button Grid.Row="5"
                        Grid.ColumnSpan="2"
                        Margin="10"
                        Padding="6"
                        FontSize="16"
                        Content="{Binding ButtonTextDisplay}"
                        BorderBrush="#68F145"
                        BorderThickness="3"
                        Background="WhiteSmoke"
                        Command="{Binding SaveEventCommand}" />
            </Grid>
        </GroupBox>

        <!-- ===================== -->
        <!-- BOTTOM ACTIONS -->
        <!-- ===================== -->

        <StackPanel Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">



            <Button Width="200"
        Padding="5"
        FontSize="18"
        Background="WhiteSmoke"
        BorderBrush="Red"
        BorderThickness="3"
        Content="Delete event"
        Command="{Binding DeleteEventCommand}"/>


        </StackPanel>

    </Grid>
</UserControl>
