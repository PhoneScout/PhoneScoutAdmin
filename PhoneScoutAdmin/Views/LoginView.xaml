<Window x:Class="PhoneScoutAdmin.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PhoneScoutAdmin.Views"
             Height="540" Width="270">

    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Image Source="/Images/PhoneScoutLogo.png"
           Margin="10"
           HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1"
               Text="Login"
               Margin="0,10"
               HorizontalAlignment="Center"
               FontWeight="Bold"
               FontSize="24"/>

        <StackPanel Grid.Row="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">

            <Label Content="E-mail address:" 
               FontSize="15" 
               FontStyle="Italic" HorizontalAlignment="Center"/>

            <TextBox Width="200"
                 Margin="0,5"
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" BorderBrush="#2300B3"/>

            <Label Content="Password:" 
               Margin="0,5,0,0"
               FontSize="15"
               FontStyle="Italic" HorizontalAlignment="Center"/>

            <PasswordBox x:Name="PasswordBox"
                     Width="200"
                     Margin="0,0,0,20" BorderBrush="#68F145"/>
        </StackPanel>

        <Button Grid.Row="3"
            Content="Login"
            Width="180"
            Padding="5"
            Background="White"
            Foreground="#80A4CB"
            BorderBrush="#80A4CB"
            BorderThickness="3"
            HorizontalAlignment="Center"
            Command="{Binding LoginCommand}"
            CommandParameter="{Binding ElementName=PasswordBox}"/>

        <TextBlock Grid.Row="4"
               Text="{Binding Message}"
               Foreground="{Binding MessageColor}"
               Margin="0,10"
               TextWrapping="Wrap"
               HorizontalAlignment="Center"/>
    </Grid>
</Window>
