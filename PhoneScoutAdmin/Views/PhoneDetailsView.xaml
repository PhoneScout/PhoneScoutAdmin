<Window x:Class="PhoneScoutAdmin.PhoneDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PhoneScoutAdmin.ViewModels"
        xmlns:views="clr-namespace:PhoneScoutAdmin.Views"
        xmlns:conv="clr-namespace:PhoneScoutAdmin.Converters"
        Title="PhoneDetails" Height="750" Width="1300"
        Background="#f5f5f5">
    
    
    <Window.Resources>

        <conv:ReferenceEqualsConverter x:Key="ReferenceEqualsConverter"/>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="15,10,15,0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background" Value="#80A4CB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="FontWeight" Value="Normal"/>

            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource ReferenceEqualsConverter}">
                            <Binding Path="CurrentViewModel"/>
                            <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>

                    <Setter Property="Background" Value="#2300B3"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        
        <DataTemplate DataType="{x:Type vm:GeneralInfosViewModel}">
            <views:GeneralInfosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CPUdetailsViewModel}">
            <views:CPUdetailsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SensorsViewModel}">
            <views:SensorsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScreenViewModel}">
            <views:ScreenView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ConnectivityViewModel}">
            <views:ConnectivityView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BatteryChargingViewModel}">
            <views:BatteryChargingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BodySpeakerViewModel}">
            <views:BodySpeakerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CameraSectionViewModel}">
            <views:CameraSectionView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CameraViewModel}">
            <views:CameraView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ColorSectionViewModel}">
            <views:ColorSectionView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ColorViewModel}">
            <views:ColorView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RamStorageSectionViewModel}">
            <views:RamStorageSectionView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RamStorageViewModel}">
            <views:RamStorageView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ImageViewModel}">
            <views:ImageView/>
        </DataTemplate>

    </Window.Resources>

    <DockPanel>
        <!-- MENU -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Activities">
                <MenuItem Header="Exit application" Command="{Binding ExitApp}"/>
            </MenuItem>
        </Menu>

        <!-- MAIN CONTENT -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="8*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="8*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <!--Logo-->
            <WrapPanel Orientation="Horizontal" >
                <Image Grid.Row="0" Grid.Column="0" Source="/Images/ImagePhoneScoutLogo.png" Margin="5"/>
                <Label Grid.Row="0" Grid.Column="0" FontSize="24" FontWeight="Bold" Content="Phone" VerticalAlignment="Center" Foreground="#2300B3"/>
                <Label Grid.Row="0" Grid.Column="0" FontSize="24" FontWeight="Bold" Content="Scout" VerticalAlignment="Center" Foreground="#68F145" Margin="-5,0,0,0"/>
            </WrapPanel>

            <!--Copyright-->
            <WrapPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left">
                <Label Content="©2026 PhoneScout."/>
                <Label Content="All rights reserved."/>
            </WrapPanel>
            <WrapPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical">
                <Label Content="EST. 2025" HorizontalAlignment="Left"/>
                <Label Content="phonescoutofficial@gmail.com" HorizontalAlignment="Right"/>
            </WrapPanel>

            <!--Header-->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding GeneralInfosVM.PhoneNameDisplay}" FontSize="28" FontWeight="Bold" Foreground="#2300B3"/>

            </StackPanel>


            <!--Side menu-->
            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical" Background="#80A4CB">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0"
Content="General Informations"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding GeneralInfosVM}"
BorderBrush="{Binding GeneralInfosVM.ProgressBorder}"
Command="{Binding ShowGeneralInfosCommand}"/>

                    <Button Grid.Row="1"
Content="CPU"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding CpuVM}"
BorderBrush="{Binding CpuVM.ProgressBorder}"
Command="{Binding ShowCpuCommand}"/>

                    <Button Grid.Row="2"
Content="Sensors"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding SensorsVM}"
BorderBrush="{Binding SensorsVM.ProgressBorder}"
Command="{Binding ShowSensorsCommand}"/>

                    <Button Grid.Row="3"
Content="Screen"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding ScreenVM}"
BorderBrush="{Binding ScreenVM.ProgressBorder}"
Command="{Binding ShowScreenCommand}"/>

                    <Button Grid.Row="4"
Content="Connectivity"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding ConnectivityVM}"
BorderBrush="{Binding ConnectivityVM.ProgressBorder}"
Command="{Binding ShowConnectivityCommand}"/>

                    <Button Grid.Row="5"
Content="Battery and Charging"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding BatteryChargingVM}"
BorderBrush="{Binding BatteryChargingVM.ProgressBorder}"
Command="{Binding ShowBatteryChargingCommand}"/>

                    <Button Grid.Row="6"
Content="Body and Speaker"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding BodySpeakerVM}"
BorderBrush="{Binding BodySpeakerVM.ProgressBorder}"
Command="{Binding ShowBodySpeakerCommand}"/>

                    <Button Grid.Row="7"
Content="Camera"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding CameraSectionVM}"
Command="{Binding ShowCameraCommand}"/>

                    <Button Grid.Row="8"
Content="Ram / Storage"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding RamStorageSectionVM}"
Command="{Binding ShowRamStorageCommand}"/>

                    <Button Grid.Row="9"
Content="Color"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding ColorSectionVM}"
Command="{Binding ShowColorCommand}"/>

                    <Button Grid.Row="10"
Content="Images"
Style="{StaticResource MenuButtonStyle}"
Tag="{Binding ImageVM}"
Command="{Binding ShowImagesCommand}"/>



                </Grid>
            </StackPanel>

            <!--Main Content-->

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>                    
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>


                <ContentControl Grid.Row="0" Grid.Column="1"
                x:Name="MainContent"
                Content="{Binding CurrentViewModel}" />








                <StackPanel Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5">
                
                <StackPanel Orientation="Vertical" Grid.Row="1">
                        <StackPanel Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Label Content="Full phone progress: " HorizontalAlignment="Center" FontSize="16" FontStyle="Italic"/>
                            <Label Content="{Binding TotalProgress}" FontSize="16" FontWeight="Bold"/>
                            <Label Content=" / 7 " FontSize="16"/>

                        </StackPanel>
                    <ProgressBar
    Minimum="0"
    Maximum="7"
    Height="20"
                        Width="500" Foreground="#68F145" BorderBrush="#2300B3"
    Value="{Binding TotalProgress, Mode=OneWay}" />


                    </StackPanel>

                    <Button Grid.Row="4"
        Grid.ColumnSpan="2"
        Margin="50,0,50,0"
        FontSize="20"
                            Padding="1" Width="200" Height="40"
        Content="Save changes"
                            FontWeight="Bold"
        BorderBrush="#68F145"
        BorderThickness="3"
        Background="WhiteSmoke"
                            Foreground="#68F145"
        Command="{Binding SavePhoneCommand}" />


                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
