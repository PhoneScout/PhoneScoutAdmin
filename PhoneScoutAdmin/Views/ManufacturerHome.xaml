<Window x:Class="PhoneScoutAdmin.Views.ManufacturerHome"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhoneScoutAdmin.ViewModels"
             xmlns:views="clr-namespace:PhoneScoutAdmin.Views"
             Height="750" Width="1300"
        Background="White">

    <DockPanel LastChildFill="True">

        <!-- MENU -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Activities">
                <MenuItem Header="Sign out" Command="{Binding SignOut}"/>
                <MenuItem Header="Exit application" Command="{Binding ExitApp}"/>
            </MenuItem>
        </Menu>

        <!-- MAIN GRID -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <!-- Side menu -->
                <ColumnDefinition Width="8*"/>
                <!-- Content -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Main content fills remaining space -->
                <RowDefinition Height="40"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- LOGO -->
            <WrapPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                <Image Source="/Images/ImagePhoneScoutLogo.png" Height="50" Margin="5"/>
                <Label FontSize="24" FontWeight="Bold" Content="Phone" VerticalAlignment="Center" Foreground="#2300B3"/>
                <Label FontSize="24" FontWeight="Bold" Content="Scout" VerticalAlignment="Center" Foreground="#68F145" Margin="-5,0,0,0"/>
            </WrapPanel>

            <!-- HEADER CENTER -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,20,5">
                <TextBlock Text=" Home" FontSize="28" FontWeight="Bold" Foreground="#68F145"/>
            </StackPanel>

            <!-- HEADER RIGHT -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,5">
                <TextBlock Text="Welcome " FontSize="22" FontStyle="Italic"/>
                <TextBlock Text="{Binding ActiveManufacturerName}" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text=" !" FontSize="22"/>
            </StackPanel>

            <!-- SIDE MENU -->
            <StackPanel Grid.Row="1" Grid.Column="0" Background="#80A4CB" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Button Content="Manage phones" Margin="15,30,15,10" FontSize="16" Width="180" Padding="5" Background="#80A4CB" Foreground="White" BorderBrush="White" BorderThickness="3" Command="{Binding ShowPhonesCommand}"/>
                <Button Content="Manage manufacturers" Margin="15,25,15,10" FontSize="16" Width="180" Padding="5" Background="#80A4CB" Foreground="White" BorderBrush="White" BorderThickness="3" Command="{Binding ShowManufacturerCommand}"/>
                <Button Content="Manage events" Margin="15,25,15,10" FontSize="16" Width="180" Padding="5" Background="#80A4CB" Foreground="White" BorderBrush="White" BorderThickness="3" Command="{Binding ShowEventsCommand}"/>
            </StackPanel>

            <!-- MAIN CONTENT AREA -->
            <ContentControl Grid.Row="1" Grid.Column="1"
                            x:Name="MainContent"
                            Content="{Binding CurrentView}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>

            <!-- FOOTER -->
            <WrapPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left" Margin="5">
                <Label Content="©2026 PhoneScout."/>
                <Label Content="All rights reserved."/>
            </WrapPanel>

            <WrapPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left" Margin="5">
                <Label Content="EST. 2025"/>
                <Label Content="phonescoutofficial@gmail.com"/>
            </WrapPanel>

        </Grid>
    </DockPanel>
</Window>